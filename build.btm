@setlocal
@echo off
:: Demo of building, and using, PureBasicTCCPlugin
if plugin PureBasicTCCPlugin plugin /u PureBasicTCCPlugin
:: pbc is an alias : "C:\Program Files\PureBasic\Compilers\pbcompiler.exe"
if isalias pbc pbc /dll PureBasicTCCPlugin.pb /exe "PureBasicTCCPlugin.dll"
plugin /l PureBasicTCCPlugin.dll
plugin /i PureBasicTCCPlugin
echo @Reverse: %@PureBasicTCCPlugin$Reverse[Today]
echo @PlusOne: %@PlusOne[27]
echo _hello  : %_hello
echos Dummy   :` `
Dummy Test
endlocal
